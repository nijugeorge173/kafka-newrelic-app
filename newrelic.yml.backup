# New Relic Java Agent Configuration
# Replace YOUR_NEW_RELIC_LICENSE_KEY with your actual key from:
#   https://one.newrelic.com/api-keys
#
# Full reference: https://docs.newrelic.com/docs/apm/agents/java-agent/configuration/java-agent-configuration-config-file/

common: &default_settings

  # ---- Required ----
  license_key: 
  app_name: Kafka New Relic Demo

  # ---- EU region endpoints (license key prefix: eu01) ----
  host: collector.eu01.nr-data.net

  # ---- Distributed Tracing ----
  distributed_tracing:
    enabled: true

  span_events:
    enabled: true
    max_samples_stored: 4000

  # ---- Transaction Tracing ----
  transaction_tracer:
    enabled: true
    transaction_threshold: 0.5
    record_sql: obfuscated
    stack_trace_threshold: 0.5
    explain_enabled: true
    explain_threshold: 0.5

  # ---- Error Collection ----
  error_collector:
    enabled: true
    ignore_status_codes: 404

  # ---- Custom Insights Events ----
  custom_insights_events:
    enabled: true
    max_samples_stored: 30000

  # ---- Metric + Event Ingest (EU) ----
  metric_ingest_uri: https://metric-api.eu.newrelic.com/metric/v1
  event_ingest_uri: https://insights-collector.eu01.nr-data.net/v1/accounts/events

  # ---- JMX ----
 # jmx:
#    enabled: true

 # kafka.metrics.as_events.enabled: true

  # ---- Kafka instrumentation modules (agent 8.21.0) ----
  class_transformer:
    # enhancements: distributed tracing headers + MessageBroker spans for produce/consume
    kafka-clients-enhancements:
      enabled: true
    # metrics: producer/consumer throughput, latency, error rates
    kafka-clients-metrics:
      enabled: false
    kafka-clients-node-metrics:
      enabled: true
    kafka-clients-config:
      enabled: true
  # ---- Labels applied to all data ----
  labels:
    environment: development
    team: platform
    application: kafka-demo

  # ---- Logging ----
  log_level: info
  log_daily: true
  log_file_count: 3
  log_limit_in_kbytes: 10240
  log_file_name: newrelic_agent.log

  # ---- Thread Profiler ----
  thread_profiler:
    enabled: true

  audit_mode: false

# Profiles — run with -Dnewrelic.environment=production to activate
development:
  <<: *default_settings
  app_name: Kafka New Relic Demo (Dev)
  log_level: fine

production:
  <<: *default_settings
  app_name: Kafka New Relic Demo
  log_level: info
